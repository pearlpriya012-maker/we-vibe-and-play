// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rooms — any authenticated user can read, create, update
    // Rooms are code-protected; auth is the main security boundary
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.hostId;

      // UNO game — any authenticated participant can read/write
      match /uno/{doc} {
        allow read, write: if request.auth != null;
      }

      // Pictionary game — any authenticated participant can read/write
      match /pictionary/{doc} {
        allow read, write: if request.auth != null;
      }

      // Word Chain game — any authenticated participant can read/write
      match /wordchain/{doc} {
        allow read, write: if request.auth != null;
      }

      // Messages — any authenticated user in the room can read/write
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
